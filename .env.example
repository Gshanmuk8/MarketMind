# ── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Supabase ────────────────────────────────────────────────────────
# Database (Prisma → Supabase PostgreSQL):
#   DATABASE_URL  = pooled connection (Transaction mode, port 6543, pgbouncer)
#   DIRECT_URL    = direct connection (port 5432) — used for migrations
# Find both in: Supabase Dashboard → Project Settings → Database
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Auth + Storage (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Server-only. Bypasses RLS — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=""

# Google & GitHub OAuth are configured in the Supabase Dashboard
# (Authentication → Providers), not via env vars here.

# ── AI Providers ────────────────────────────────────────────────────
# OpenRouter is the primary gateway — the only key required to start.
OPENROUTER_API_KEY=""
# Optional direct-provider keys (used when set, otherwise routed via OpenRouter)
OPENAI_API_KEY=""
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""
GROQ_API_KEY=""
CEREBRAS_API_KEY=""
DEEPSEEK_API_KEY=""

# ── Monitoring sources ──────────────────────────────────────────────
# Optional: raises GitHub API rate limits for the engineering monitor
GITHUB_TOKEN=""

# ── Cache (Upstash Redis) ───────────────────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Background Jobs (Inngest) ───────────────────────────────────────
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ── Notifications ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""
RESEND_API_KEY=""
# Sender for digests/alerts. Default (onboarding@resend.dev) only delivers
# to the Resend account owner — use your verified domain in production.
EMAIL_FROM="MarketMind AI <onboarding@resend.dev>"
